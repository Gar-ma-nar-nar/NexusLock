{
  "expo": {
    "name": "Nexus-Lock",
    "slug": "nexus-lock",
    "version": "2.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nexuslock",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E14"
    },
    "plugins": [
      ["expo-audio"],
      ["expo-local-authentication"],
      ["react-native-vision-camera", {
        "cameraPermission": "Nexus-Lock needs the camera to detect faces."
      }]
    ],
    "android": {
      "permissions": ["CAMERA", "RECORD_AUDIO", "USE_BIOMETRIC", "FOREGROUND_SERVICE", "VIBRATE"]
    }
  }
}
